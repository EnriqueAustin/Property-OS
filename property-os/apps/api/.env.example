PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=property_os

# JWT Authentication
JWT_SECRET=change_me_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Redis (for caching, rate limiting, sessions)
REDIS_HOST=localhost
REDIS_PORT=16379

# PayFast (SA payment gateway)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=http://localhost:3000/book/payment/success
PAYFAST_CANCEL_URL=http://localhost:3000/book/payment/cancel
PAYFAST_NOTIFY_URL=http://localhost:3001/api/payments/payfast/itn

# Email (Resend — get API key from https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=PropertyOS <noreply@propertyos.co.za>

# WhatsApp provider (twilio or clickatell)
WHATSAPP_PROVIDER=

# WhatsApp (optional)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Accounting Integrations — Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Accounting Integrations — Sage Business Cloud
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=

# Accounting Integrations — QuickBooks Online
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_SANDBOX=true

# Accounting Integrations — Zoho Books
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Accounting Integrations — FreshBooks
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=

# Encryption key for storing OAuth tokens at rest (change in production!)
ACCOUNTING_ENCRYPTION_KEY=change-this-in-production-use-random-32-chars

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:3000

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=http://localhost:3000

# Database synchronize (set to false in production — use migrations instead)
DB_SYNCHRONIZE=false

# Database connection pool size (default 20, increase for production)
DB_POOL_MAX=20

# JWT refresh secret (separate from main JWT_SECRET)
JWT_REFRESH_SECRET=change_me_refresh_secret
